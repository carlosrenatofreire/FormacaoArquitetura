@model SupplierViewModel

<div style="padding-top: 20px">
    <div>
        <hr />
        <h4>Endereço</h4>
    </div>

    @if (Model?.Address != null)
    {
        <table class="table table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Address!.Street)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Address!.Number)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Address!.Complement)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Address!.Neighborhood)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Address!.PostalCode)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Address!.City)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Address!.State)
                    </th>
                </tr>
            </thead>

            <tr>
                <td>
                    @Html.DisplayFor(model => model.Address!.Street)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Address!.Number)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Address!.Complement)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Address!.Neighborhood)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Address!.PostalCode)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Address!.City)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Address!.State)
                </td>
            </tr>
        </table>
    }
    else
    {
        <div class="alert alert-info">Sem endereço registado.</div>
    }
</div>
